# VOX — Environment Configuration
# Copy this to .env and fill in your values
# NEVER commit .env — it's gitignored

# Picovoice (wake word detection)
# Get a free key at https://console.picovoice.ai/
PORCUPINE_ACCESS_KEY=your_access_key_here

# Ollama (should be running locally)
OLLAMA_HOST=http://127.0.0.1:11434
# Recommended models (pick one that fits your GPU):
#   qwen2.5:14b   — 9GB VRAM, excellent tool calling (default, recommended for 24GB GPUs)
#   llama3.2      — 2GB VRAM, basic (for testing or low-VRAM systems)
#   llama3.3:70b  — 22GB VRAM, best quality (tight fit on 24GB with STT+TTS)
OLLAMA_MODEL=qwen2.5:14b

# User profile
# USER_EMAIL — default recipient for "email me" / "send me" (no address needed)
# USER_EMAIL=you@example.com

# Email (optional — for send_email tool)
# Supports any SMTP server: local relay, Gmail, SES, etc.
# Auto-detects STARTTLS (uses it if available, skips for plaintext relays)
# SMTP_HOST=your-relay.local
# SMTP_PORT=587
# SMTP_USER=your_smtp_user
# SMTP_PASSWORD=your_smtp_password
# SMTP_FROM=vox@yourdomain.com

# Home Assistant (optional)
# HASS_URL=http://127.0.0.1:8123
# HASS_TOKEN=your_long_lived_access_token_here

# Audio device indices (run `vox --list-devices` to find yours)
# MIC_DEVICE_INDEX=0
# SPEAKER_DEVICE_INDEX=0

# STT (Faster-Whisper)
# WHISPER_MODEL=base.en
# WHISPER_DEVICE=cuda

# TTS engine: "piper" (fast) or "xtts" (voice cloning)
# TTS_ENGINE=piper

# Image generation (optional — requires pip install -e ".[image]")
# IMAGE_MODEL=runwayml/stable-diffusion-v1-5
# IMAGE_NSFW_FILTER=on
# IMAGE_STEPS=30
# IMAGE_WIDTH=512
# IMAGE_HEIGHT=512
# IMAGE_NEGATIVE_PROMPT=deformed, bad anatomy, extra limbs, mutated hands, poorly drawn face, blurry, low quality, watermark, text, signature, cropped

# Persona (optional — gives VOX a visual identity for selfie generation)
# When set, VOX can generate "selfies" and pictures of herself using these settings.
# VOX_PERSONA_NAME=Luna
# VOX_PERSONA_DESCRIPTION=a young woman with long dark brown hair, green eyes, fair skin
# VOX_PERSONA_STYLE=photorealistic, natural lighting, high detail, 8k
